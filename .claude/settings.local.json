{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(done)",
      "Bash(npm run build:*)",
      "Bash(npx jest:*)",
      "Bash(npm install:*)",
      "Bash(npm test:*)",
      "Bash(npx commitlint:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(npx shadcn-svelte@latest add select)",
      "Bash(npx shadcn-svelte@latest add select --overwrite)",
      "Bash(npx cdk:*)",
      "Bash(pnpm deploy:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "awslabs.cdk-mcp-server"
  ],
  "statusLine": {
    "type": "command",
    "command": "sh E:\\code\\elevensys-cdk\\.claude\\statusline-command.sh"
